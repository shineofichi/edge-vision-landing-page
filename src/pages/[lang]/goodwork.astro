---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import Hero from '../../components/goodwork/Hero';
import Features from '../../components/goodwork/Features';
import CTA from '../../components/goodwork/CTA';
import {
  buildBreadcrumbSchema,
  buildOrganizationSchema,
  buildSoftwareApplicationSchema,
  getPageSeo,
  secondaryLocales,
} from '../../lib/i18n';

export function getStaticPaths() {
  return secondaryLocales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang;
const pageKey = 'goodwork';
const seo = getPageSeo(lang, pageKey);
const structuredData = [
  buildOrganizationSchema(),
  buildSoftwareApplicationSchema(lang),
  buildBreadcrumbSchema(lang, pageKey),
];
---

<Layout
  title={seo.title}
  description={seo.description}
  lang={seo.lang}
  canonical={seo.canonical}
  alternates={seo.alternates}
  ogImage={seo.ogImage}
  ogImageAlt={seo.ogImageAlt}
  ogImageWidth={seo.ogImageWidth}
  ogImageHeight={seo.ogImageHeight}
  ogLocale={seo.ogLocale}
  structuredData={structuredData}
>
  <main>
    <Navbar client:load lang={lang} pageKey={pageKey} />
    <Hero client:load lang={lang} />
    <Features client:visible lang={lang} />
    <CTA client:visible lang={lang} />
    <Footer client:load lang={lang} />
  </main>
</Layout>
